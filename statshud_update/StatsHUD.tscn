[gd_scene format=3 uid="uid://statshud_yahwajeon"]

[ext_resource type="Script" path="res://scripts/StatsHUD.gd" id="1_statshud_script"]

; ══════════════════════════════════════════════
; StatsHUD — 경험치·엽전 상시 표시 HUD
;
; 노드 트리:
; StatsHUD [CanvasLayer]                       ← layer=5 (GameUI 아래, 게임월드 위)
; └─ HUDPanel [PanelContainer]                 ← 좌상단 고정 패널
;    └─ HUDLayout [VBoxContainer]
;       ├─ LevelRow [HBoxContainer]            ← "Lv.1" 레이블
;       │  ├─ LblLevelTitle [Label]            "레벨"
;       │  └─ LblLevel [Label]                 "1"
;       ├─ ExpBarRow [VBoxContainer]           ← 경험치 바 영역
;       │  ├─ ExpBarBG [PanelContainer]        ← 경험치 바 배경
;       │  │  └─ ExpBarFill [ColorRect]        ← 경험치 채움 (width 비율로 조절)
;       │  └─ LblExp [Label]                   "0 / 50 EXP"
;       └─ CoinRow [HBoxContainer]             ← 엽전 표시
;          ├─ LblCoinTitle [Label]             "엽전"
;          └─ LblCoin [Label]                  "0"
;
; PopupLayer [CanvasLayer]                     ← layer=6, 팝업 텍스트 전용
; └─ PopupContainer [Control]                  ← 전체 화면 크기
;    ├─ PopupExp [Label]                       "+10 EXP" (획득 시 위로 올라가며 사라짐)
;    └─ PopupCoin [Label]                      "+5 엽전" (획득 시 위로 올라가며 사라짐)
; ══════════════════════════════════════════════

; ── StatsHUD CanvasLayer ──────────────────────
[node name="StatsHUD" type="CanvasLayer"]
layer = 5
script = ExtResource("1_statshud_script")

; ── HUD 패널 (좌상단 고정) ─────────────────────
[node name="HUDPanel" type="PanelContainer" parent="."]
anchor_left = 0.0
anchor_top = 0.0
anchor_right = 0.0
anchor_bottom = 0.0
offset_left = 10
offset_top = 10
offset_right = 260
offset_bottom = 130
grow_horizontal = 1
grow_vertical = 1

[node name="HUDLayout" type="VBoxContainer" parent="HUDPanel"]
anchor_right = 1.0
anchor_bottom = 1.0
offset_left = 8
offset_top = 6
offset_right = -8
offset_bottom = -6

; ── 레벨 행 ───────────────────────────────────
[node name="LevelRow" type="HBoxContainer" parent="HUDPanel/HUDLayout"]

[node name="LblLevelTitle" type="Label" parent="HUDPanel/HUDLayout/LevelRow"]
text = "레벨"
custom_minimum_size = Vector2(40, 0)

[node name="LblLevel" type="Label" parent="HUDPanel/HUDLayout/LevelRow"]
size_flags_horizontal = 3
text = "1"

; ── 경험치 바 영역 ────────────────────────────
[node name="ExpBarRow" type="VBoxContainer" parent="HUDPanel/HUDLayout"]

[node name="ExpBarBG" type="PanelContainer" parent="HUDPanel/HUDLayout/ExpBarRow"]
custom_minimum_size = Vector2(0, 14)

[node name="ExpBarFill" type="ColorRect" parent="HUDPanel/HUDLayout/ExpBarRow/ExpBarBG"]
color = Color(0.2, 0.8, 0.3, 1.0)
anchor_left = 0.0
anchor_top = 0.0
anchor_right = 0.0
anchor_bottom = 1.0
offset_right = 0
grow_horizontal = 1

[node name="LblExp" type="Label" parent="HUDPanel/HUDLayout/ExpBarRow"]
horizontal_alignment = 1
text = "0 / 50 EXP"

; ── 엽전 행 ───────────────────────────────────
[node name="CoinRow" type="HBoxContainer" parent="HUDPanel/HUDLayout"]

[node name="LblCoinTitle" type="Label" parent="HUDPanel/HUDLayout/CoinRow"]
text = "엽전"
custom_minimum_size = Vector2(40, 0)

[node name="LblCoin" type="Label" parent="HUDPanel/HUDLayout/CoinRow"]
size_flags_horizontal = 3
text = "0"

; ══════════════════════════════════════════════
; 팝업 텍스트 레이어 (획득량 플로팅 텍스트)
; ══════════════════════════════════════════════
[node name="PopupLayer" type="CanvasLayer" parent="."]
layer = 6

[node name="PopupContainer" type="Control" parent="PopupLayer"]
anchor_right = 1.0
anchor_bottom = 1.0

[node name="PopupExp" type="Label" parent="PopupLayer/PopupContainer"]
visible = false
position = Vector2(270, 80)
text = "+10 EXP"
modulate = Color(0.3, 1.0, 0.4, 1.0)

[node name="PopupCoin" type="Label" parent="PopupLayer/PopupContainer"]
visible = false
position = Vector2(270, 100)
text = "+5 엽전"
modulate = Color(1.0, 0.9, 0.2, 1.0)

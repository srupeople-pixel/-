[gd_scene format=3 uid="uid://statshud_yahwajeon"]

[ext_resource type="Script"  path="res://scripts/StatsHUD.gd"          id="1_statshud_script"]
[ext_resource type="Script"  path="res://scripts/ExpBar.gd"             id="2_expbar_script"]
[ext_resource type="Texture2D" path="res://assets/hud/exp_bar_bg.png"   id="3_exp_bg"]
[ext_resource type="Texture2D" path="res://assets/hud/exp_bar_fill.png" id="4_exp_fill"]
[ext_resource type="Texture2D" path="res://assets/hud/hud_panel_bg.png" id="5_panel_bg"]
[ext_resource type="Texture2D" path="res://assets/hud/hp_bar_bg.png"    id="6_hp_bg"]
[ext_resource type="Texture2D" path="res://assets/hud/hp_bar_fill.png"  id="7_hp_fill"]
[ext_resource type="Texture2D" path="res://assets/hud/mp_bar_bg.png"    id="8_mp_bg"]
[ext_resource type="Texture2D" path="res://assets/hud/mp_bar_fill.png"  id="9_mp_fill"]

; ══════════════════════════════════════════════
; StatsHUD — 상시 표시 HUD
;
; 노드 트리:
; StatsHUD [CanvasLayer]  layer=5
; ├─ TopExpArea [VBoxContainer]           ← 화면 최상단 경험치 바 영역
; │  ├─ ExpBar [TextureProgressBar]       ← ExpBar.gd 부착
; │  └─ ExpInfoRow [HBoxContainer]
; │     ├─ LblExp [Label]                 "0 / 50 EXP" (가운데 확장)
; │     └─ LblCoin [Label]                "엽전 0" (우측 정렬)
; ├─ HUDPanel [NinePatchRect]             ← 좌상단 스탯 패널
; │  └─ HUDLayout [VBoxContainer]
; │     ├─ LblLevel [Label]               "레벨 1" (가운데 정렬)
; │     ├─ Spacer [Control]               6px 여백
; │     ├─ HpBar [TextureProgressBar]     200px 너비
; │     ├─ LblHp [Label]                  "100 / 100 HP"
; │     ├─ MpBar [TextureProgressBar]     200px 너비
; │     └─ LblMp [Label]                  "100 / 100 MP"
; └─ PopupLayer [CanvasLayer]  layer=6
;    └─ PopupContainer [Control]
;       ├─ PopupExp  [Label]              "+10 EXP"
;       └─ PopupCoin [Label]              "+5 엽전"
; ══════════════════════════════════════════════

[node name="StatsHUD" type="CanvasLayer"]
layer = 5
script = ExtResource("1_statshud_script")

; ── 화면 최상단 경험치 바 영역 ────────────────
[node name="TopExpArea" type="VBoxContainer" parent="."]
anchor_left   = 0.0
anchor_top    = 0.0
anchor_right  = 1.0
anchor_bottom = 0.0
offset_left   = 0
offset_top    = 0
offset_right  = 0
offset_bottom = 44
theme_override_constants/separation = 2

[node name="ExpBar" type="TextureProgressBar" parent="TopExpArea"]
size_flags_horizontal = 3
custom_minimum_size = Vector2(0, 20)
texture_under    = ExtResource("3_exp_bg")
texture_progress = ExtResource("4_exp_fill")
nine_patch_stretch = true
min_value = 0.0
max_value = 100.0
value     = 0.0
script = ExtResource("2_expbar_script")

; ── 경험치 텍스트 + 엽전 (한 행) ──────────────
[node name="ExpInfoRow" type="HBoxContainer" parent="TopExpArea"]
size_flags_horizontal = 3

[node name="LblExp" type="Label" parent="TopExpArea/ExpInfoRow"]
size_flags_horizontal = 3
horizontal_alignment  = 1
text = "0 / 50 EXP"

[node name="LblLevel" type="Label" parent="TopExpArea/ExpInfoRow"]
text = "레벨 1"

[node name="LblCoin" type="Label" parent="TopExpArea/ExpInfoRow"]
text = "  엽전 0"

; ── HUD 패널 (NinePatchRect — 이미지 배경) ────
[node name="HUDPanel" type="NinePatchRect" parent="."]
texture = ExtResource("5_panel_bg")
patch_margin_left   = 0
patch_margin_top    = 0
patch_margin_right  = 0
patch_margin_bottom = 0
offset_left   = 10
offset_top    = 48
offset_right  = 300
offset_bottom = 190

[node name="HUDLayout" type="VBoxContainer" parent="HUDPanel"]
anchor_right  = 1.0
anchor_bottom = 1.0
offset_left   = 12
offset_top    = 8
offset_right  = -12
offset_bottom = -8
theme_override_constants/separation = 4

; ── HP/MP 상단 여백 ───────────────────────────
[node name="BarSpacer" type="Control" parent="HUDPanel/HUDLayout"]
custom_minimum_size = Vector2(0, 20)

; ── HP 바 (TextureProgressBar, 200px) ─────────
[node name="HpBar" type="TextureProgressBar" parent="HUDPanel/HUDLayout"]
custom_minimum_size   = Vector2(200, 20)
size_flags_horizontal = 4
texture_under    = ExtResource("6_hp_bg")
texture_progress = ExtResource("7_hp_fill")
nine_patch_stretch = true
min_value = 0.0
max_value = 100.0
value     = 100.0

; ── HP 수치 텍스트 ─────────────────────────────
[node name="LblHp" type="Label" parent="HUDPanel/HUDLayout"]
size_flags_horizontal = 3
horizontal_alignment  = 1
text = "100 / 100 HP"

; ── MP 바 (TextureProgressBar, 200px) ─────────
[node name="MpBar" type="TextureProgressBar" parent="HUDPanel/HUDLayout"]
custom_minimum_size   = Vector2(200, 20)
size_flags_horizontal = 4
texture_under    = ExtResource("8_mp_bg")
texture_progress = ExtResource("9_mp_fill")
nine_patch_stretch = true
min_value = 0.0
max_value = 100.0
value     = 100.0

; ── MP 수치 텍스트 ─────────────────────────────
[node name="LblMp" type="Label" parent="HUDPanel/HUDLayout"]
size_flags_horizontal = 3
horizontal_alignment  = 1
text = "100 / 100 MP"

; ══════════════════════════════════════════════
; 팝업 텍스트 레이어
; ══════════════════════════════════════════════
[node name="PopupLayer" type="CanvasLayer" parent="."]
layer = 6

[node name="PopupContainer" type="Control" parent="PopupLayer"]
anchor_right  = 1.0
anchor_bottom = 1.0

[node name="PopupExp" type="Label" parent="PopupLayer/PopupContainer"]
visible  = false
position = Vector2(280, 60)
text     = "+10 EXP"
modulate = Color(0.3, 1.0, 0.4, 1.0)

[node name="PopupCoin" type="Label" parent="PopupLayer/PopupContainer"]
visible  = false
position = Vector2(280, 80)
text     = "+5 엽전"
modulate = Color(1.0, 0.9, 0.2, 1.0)
